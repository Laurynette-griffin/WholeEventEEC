Random:setSeed = on
Random:seed = 0

! Beam setup
Beams:idA = -11                ! positron
Beams:idB = 11                 ! electron
Beams:eCM = 91.2               ! center-of-mass energy in GeV

! Physics process: e+e- -> gamma*/Z0 -> hadrons
WeakSingleBoson:ffbar2gmZ = on

! Turn off all Z decay channels, except to quarks
23:onMode = off
23:onIfAny = 1 2 3 4 5         ! Z → u, d, s, c, b

! Tune for e+e- (LEP)
Tune:ee = 7

! Disable PDFs (not needed for leptons)
PDF:lepton = off